# SwarmSPX Environment Configuration
# Copy to .env and fill in your values

# Claude models via CLI subprocess (uses Max plan OAuth, no API key)
CLAUDE_CLI_ENABLED=true
CLAUDE_MODEL=sonnet

# Tradier (real SPX options chain data) — optional
TRADIER_API_KEY=your_tradier_api_key
TRADIER_ACCOUNT_ID=your_account_id

# Alpaca (paper trading) — optional, for future auto-execution
ALPACA_API_KEY=your_alpaca_key
ALPACA_SECRET_KEY=your_alpaca_secret
ALPACA_ENV=paper

# Telegram alerts — optional
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Slack alerts — optional
SLACK_WEBHOOK_URL=https://hooks.slack.com/triggers/your/webhook/url

# Finnhub (supplementary market data) — optional
FINNHUB_API_KEY=your_finnhub_key
